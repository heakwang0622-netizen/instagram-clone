# --- DB (택 1) ---
# DATABASE_URL이 있으면 항상 이 값을 씁니다 (SQLite·PostgreSQL URL 모두 가능).
# 비우거나 생략하면 APP_ENV에 따라 자동 선택됩니다.
# DATABASE_URL=sqlite:///./instagram.db

# development(기본) → SQLITE_URL | production|staging → POSTGRES_* 로 DSN 조합
APP_ENV=development

# 로컬 SQLite (APP_ENV=development 이고 DATABASE_URL 미설정일 때)
SQLITE_URL=sqlite:///./instagram.db

# 서버 PostgreSQL (APP_ENV=production|staging 이고 DATABASE_URL 미설정일 때)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=secret
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=instagram

SECRET_KEY=your-secret-key
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
UPLOAD_DIR=uploads
